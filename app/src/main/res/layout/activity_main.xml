<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A1A0F">

    <!-- WebView principal -->
    <WebView
        android:id="@+id/webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible" />

    <!-- Barre de progression chargement -->
    <ProgressBar
        android:id="@+id/progress_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_alignParentTop="true"
        android:progressTint="#69F0AE"
        android:progressBackgroundTint="#0D2416"
        android:visibility="gone" />

    <!-- Ecran hors-ligne -->
    <LinearLayout
        android:id="@+id/offline_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone"
        android:background="#0A1A0F">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&#128267;"
            android:textSize="56sp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="9emePRO"
            android:textColor="#69F0AE"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pas de connexion internet"
            android:textColor="#9BBFA3"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connecte-toi a internet pour utiliser l'application."
            android:textColor="#5A7A62"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <Button
            android:id="@+id/retry_btn"
            android:layout_width="200dp"
            android:layout_height="48dp"
            android:text="Reessayer"
            android:textColor="#0A1A0F"
            android:textStyle="bold"
            android:backgroundTint="#69F0AE"
            android:stateListAnimator="@null" />

    </LinearLayout>

</RelativeLayout>
